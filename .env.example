# ──────────────────────────────────────────
# Mesh Connect — Sandbox Credentials
# ──────────────────────────────────────────

MESH_API_URL=https://sandbox-integration-api.meshconnect.com
MESH_CLIENT_ID=your_client_id_here
MESH_API_KEY=your_api_key_here
MESH_SECRET_KEY=your_secret_key_here

# Destination wallet for USDC payments (Ethereum)
DESTINATION_WALLET=0xYourWalletAddressHere

# Ethereum networkId in Mesh's system
ETHEREUM_NETWORK_ID=e3c7fdd8-b1fc-4e51-85ae-bb276e075611

# Webhook endpoint
WEBHOOK_URL=https://webhook.site/your-webhook-id

# Server
PORT=3000
